# ============================================
# DC86 Stream Toolkit - Environment Variables
# Kopiere diese Datei: cp .env.example .env
# ============================================

# ── Twitch API ──
# Erstelle eine App unter: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=deine-client-id-hier
TWITCH_CLIENT_SECRET=dein-client-secret-hier
TWITCH_REDIRECT_URI=http://localhost:8000/api/auth/callback

# ── Datenbank ──
DB_USER=dc86
DB_PASSWORD=dc86secret
DB_NAME=dc86_toolkit

# ── Backend ──
SECRET_KEY=generiere-einen-sicheren-key-hier
FRONTEND_URL=http://localhost:5173

# ── Frontend ──
VITE_API_URL=http://localhost:8000

# ── Chat-Bot ──
# Token generieren: https://twitchtokengenerator.com/
# ODER den OAuth-Token vom Toolkit-Login verwenden
# Format: oauth:xxxxxxxxxxxxxxxxxxxxxxxxx
TWITCH_BOT_TOKEN=oauth:dein-bot-token-hier
TWITCH_CHANNEL=derchrist
BOT_PREFIX=!
